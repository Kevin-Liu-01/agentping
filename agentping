from typing import Callable, Optional

VERSION = "1.0.0"

EXIT_OK = 0
EXIT_DECLINED = 20
EXIT_TIMEOUT = 124
EXIT_USAGE = 2
EXIT_PROVIDER = 3

# Outgoing ntfy messages carry this title prefix so the reply poller can ignore
# its own publishes when it reads the topic back.
NTFY_OUT_PREFIX = "[agent] "

# macOS Messages stores message dates as nanoseconds since 2001-01-01 UTC. This
# is that instant in Unix seconds, used to translate our wall clock to its clock.
APPLE_EPOCH = 978307200

# Per-verb macOS sound names (files in /System/Library/Sounds) used when a channel
# sets "sound": "auto" -- each verb gets a recognizable tone so you can tell by ear
# whether the agent is just informing you or is blocked waiting on your decision.
AUTO_SOUNDS = {"notify": "Glass", "ask": "Ping", "choose": "Pop", "confirm": "Sosumi"}


@dataclass
class Ask:
    """One request from the agent to the human."""

    verb: str                                       # notify|ask|confirm|choose
    message: str
    title: str = "Agent"
    urgency: str = "normal"                         # low|normal|high
    timeout: float = 120.0                          # seconds; 0 = wait forever
    default: str = ""                               # prefilled answer (ask)
    options: list = field(default_factory=list)     # choices (choose)
    yes: str = "Approve"
    no: str = "Deny"
    sound: str = ""                                 # macOS sound name; "" = silent

    def has_timeout(self) -> bool:
        return bool(self.timeout and self.timeout > 0)


@dataclass
class Result:
    """The outcome of a request. `status` is authoritative; exit code follows."""

    status: str          # delivered|answered|approved|denied|chosen|timeout|cancelled|error
    channel: str
    verb: str
    response: Optional[str] = None
    error: Optional[str] = None

    def exit_code(self) -> int:
        return {
            "delivered": EXIT_OK,
            "answered": EXIT_OK,
            "approved": EXIT_OK,
            "chosen": EXIT_OK,
            "suppressed": EXIT_OK,      # policy filtered it out; not an error
            "throttled": EXIT_OK,       # too soon after the last notify
            "denied": EXIT_DECLINED,
            "cancelled": EXIT_DECLINED,
            "timeout": EXIT_TIMEOUT,
            "error": EXIT_PROVIDER,
        }[self.status]


class Unsupported(Exception):
    """A channel cannot service the requested verb. We fail loud, never silently
    fall back to a different channel. One ping, one destination."""


# --------------------------------------------------------------------------- #
# macOS system backend (osascript)
# --------------------------------------------------------------------------- #

def _as_str(s: str) -> str:
    """Quote a Python string as an AppleScript string literal."""
    return '"' + s.replace("\\", "\\\\").replace('"', '\\"') + '"'


def _mac_play_sound(name: str) -> None:
    """Fire-and-forget a named macOS sound. Used for dialogs (ask/confirm/choose),
    which -- unlike `display notification` -- have no built-in sound parameter.
    Searches the user and system Sounds folders and stays silent if the name is
    empty or the file is missing, so it never blocks or errors the prompt."""
    if not name:
        return
    for base in (Path.home() / "Library" / "Sounds", Path("/System/Library/Sounds"),
                 Path("/Library/Sounds")):
        f = base / f"{name}.aiff"
        if f.is_file():
            try:
                subprocess.Popen(["afplay", str(f)],
                                 stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            except OSError:
                pass
            return


def _mac_notify(req: Ask, channel: str) -> Result:
    sound = f" sound name {_as_str(req.sound)}" if req.sound else ""
    script = f"display notification {_as_str(req.message)} with title {_as_str(req.title)}{sound}"
    cp = subprocess.run(["osascript", "-e", script], capture_output=True, text=True)
    if cp.returncode != 0:
        return Result("error", channel, "notify", error=(cp.stderr or "").strip() or "osascript failed")
    return Result("delivered", channel, "notify")


def _mac_dialog(script: str, req: Ask, channel: str, verb: str,
                on_ok: Callable[[str], Result]) -> Result:
    _mac_play_sound(req.sound)
    # The dialog self-dismisses via `giving up after`, so give osascript a few
    # extra seconds before we treat the subprocess itself as stuck.
    sp_timeout = (req.timeout + 15) if req.has_timeout() else None
    try:
        cp = subprocess.run(["osascript", "-e", script], capture_output=True,
                            text=True, timeout=sp_timeout)
    except subprocess.TimeoutExpired:
        return Result("timeout", channel, verb)
    err = cp.stderr or ""
    if cp.returncode != 0:
        if "-128" in err or "User canceled" in err:        # Cancel button / Esc
            return Result("cancelled", channel, verb)
        return Result("error", channel, verb, error=err.strip() or "osascript failed")
    out = (cp.stdout or "").strip()
    if out == "GAVEUP":
        return Result("timeout", channel, verb)
    if out.startswith("OK:"):
        return on_ok(out[3:])
    if out.startswith("BTN:"):
        return on_ok(out[4:])
    return Result("error", channel, verb, error=f"unexpected osascript output: {out!r}")


def _mac_ask(req: Ask, channel: str) -> Result:
    giving = f" giving up after {int(req.timeout)}" if req.has_timeout() else ""
    dlg = (f"display dialog {_as_str(req.message)} with title {_as_str(req.title)} "
           f'default answer {_as_str(req.default)} buttons {{"Cancel", "Send"}} '
           f'default button "Send"{giving}')
    script = f'set r to ({dlg})\nif gave up of r then return "GAVEUP"\nreturn "OK:" & text returned of r'
    return _mac_dialog(script, req, channel, "ask",
                       lambda v: Result("answered", channel, "ask", response=v))


def _mac_confirm(req: Ask, channel: str) -> Result:
    giving = f" giving up after {int(req.timeout)}" if req.has_timeout() else ""
    no_lit, yes_lit = _as_str(req.no), _as_str(req.yes)
    dlg = (f"display dialog {_as_str(req.message)} with title {_as_str(req.title)} "
           f"buttons {{{no_lit}, {yes_lit}}} default button {yes_lit}{giving}")
    script = f'set r to ({dlg})\nif gave up of r then return "GAVEUP"\nreturn "BTN:" & button returned of r'
    return _mac_dialog(script, req, channel, "confirm",
                       lambda label: Result("approved" if label == req.yes else "denied",
                                            channel, "confirm", response=label))


def _mac_choose(req: Ask, channel: str) -> Result:
    _mac_play_sound(req.sound)
    items = ", ".join(_as_str(o) for o in req.options)
    first = _as_str(req.options[0])
    script = (
        f"set chosen to (choose from list {{{items}}} "
        f"with title {_as_str(req.title)} with prompt {_as_str(req.message)} "
        f'default items {{{first}}} OK button name "Select" cancel button name "Cancel")\n'
        f'if chosen is false then return "CANCEL"\n'
        f'return "OK:" & (item 1 of chosen)'
    )
    try:
        cp = subprocess.run(["osascript", "-e", script], capture_output=True,
                            text=True, timeout=(req.timeout if req.has_timeout() else None))
    except subprocess.TimeoutExpired:
        return Result("timeout", channel, "choose")
    if cp.returncode != 0:
        return Result("error", channel, "choose", error=(cp.stderr or "").strip() or "osascript failed")
    out = (cp.stdout or "").strip()
    if out == "CANCEL":
        return Result("cancelled", channel, "choose")
    if out.startswith("OK:"):
        return Result("chosen", channel, "choose", response=out[3:])
    return Result("error", channel, "choose", error=f"unexpected osascript output: {out!r}")


# --------------------------------------------------------------------------- #
# Linux system backend (notify-send / zenity / kdialog)
# --------------------------------------------------------------------------- #

def _linux_notify(req: Ask, channel: str) -> Result:
    if not shutil.which("notify-send"):
        return Result("error", channel, "notify", error="notify-send not found (install libnotify-bin)")
    urgency = {"low": "low", "normal": "normal", "high": "critical"}.get(req.urgency, "normal")
    cp = subprocess.run(["notify-send", "-u", urgency, req.title, req.message],
                        capture_output=True, text=True)
    if cp.returncode != 0:
        return Result("error", channel, "notify", error=(cp.stderr or "").strip() or "notify-send failed")
    return Result("delivered", channel, "notify")


def _zenity(argv: list, req: Ask) -> subprocess.CompletedProcess:
    if req.has_timeout():
        argv = argv + ["--timeout", str(int(req.timeout))]
    return subprocess.run(argv, capture_output=True, text=True)


def _linux_ask(req: Ask, channel: str) -> Result:
    if shutil.which("zenity"):
        cp = _zenity(["zenity", "--entry", "--title", req.title,
                      "--text", req.message, "--entry-text", req.default], req)
    elif shutil.which("kdialog"):
        cp = subprocess.run(["kdialog", "--title", req.title, "--inputbox", req.message, req.default],
                            capture_output=True, text=True)
    else:
        raise Unsupported("no zenity/kdialog found for interactive prompts on Linux")
    if cp.returncode == 5:                                  # zenity timeout
        return Result("timeout", channel, "ask")
    if cp.returncode != 0:
        return Result("cancelled", channel, "ask")
    return Result("answered", channel, "ask", response=(cp.stdout or "").strip())


def _linux_confirm(req: Ask, channel: str) -> Result:
    if shutil.which("zenity"):
        cp = _zenity(["zenity", "--question", "--title", req.title, "--text", req.message,
                      "--ok-label", req.yes, "--cancel-label", req.no], req)
    elif shutil.which("kdialog"):
        cp = subprocess.run(["kdialog", "--title", req.title, "--yesno", req.message],
                            capture_output=True, text=True)
    else:
        raise Unsupported("no zenity/kdialog found for interactive prompts on Linux")
    if cp.returncode == 5:
        return Result("timeout", channel, "confirm")
    if cp.returncode == 0:
        return Result("approved", channel, "confirm", response=req.yes)
    return Result("denied", channel, "confirm", response=req.no)


def _linux_choose(req: Ask, channel: str) -> Result:
    if not shutil.which("zenity"):
        raise Unsupported("choose requires zenity on Linux")
    argv = ["zenity", "--list", "--radiolist", "--title", req.title,
            "--text", req.message, "--column", "", "--column", "Option"]
    for i, opt in enumerate(req.options):
        argv += ["TRUE" if i == 0 else "FALSE", opt]
    cp = _zenity(argv, req)
    if cp.returncode == 5:
        return Result("timeout", channel, "choose")
    if cp.returncode != 0:
        return Result("cancelled", channel, "choose")
    return Result("chosen", channel, "choose", response=(cp.stdout or "").strip())


# --------------------------------------------------------------------------- #
# Windows system backend (PowerShell / WScript.Shell), best effort
# --------------------------------------------------------------------------- #

def _powershell(script: str, timeout: Optional[float] = None) -> subprocess.CompletedProcess:
    return subprocess.run(["powershell", "-NoProfile", "-NonInteractive", "-Command", script],
                          capture_output=True, text=True, timeout=timeout)


def _win_notify(req: Ask, channel: str) -> Result:
    wait = 15 if req.urgency == "high" else 5
    msg, title = req.message.replace('"', "'"), req.title.replace('"', "'")
    script = f'(New-Object -ComObject WScript.Shell).Popup("{msg}", {wait}, "{title}", 64) | Out-Null'
    cp = _powershell(script)
    if cp.returncode != 0:
        return Result("error", channel, "notify", error=(cp.stderr or "").strip() or "powershell failed")
    return Result("delivered", channel, "notify")


def _win_ask(req: Ask, channel: str) -> Result:
    msg, title, dflt = (s.replace('"', "'") for s in (req.message, req.title, req.default))
    script = ('Add-Type -AssemblyName Microsoft.VisualBasic;'
              f'[Microsoft.VisualBasic.Interaction]::InputBox("{msg}", "{title}", "{dflt}")')
    try:
        cp = _powershell(script, timeout=(req.timeout if req.has_timeout() else None))
    except subprocess.TimeoutExpired:
        return Result("timeout", channel, "ask")
    if cp.returncode != 0:
        return Result("error", channel, "ask", error=(cp.stderr or "").strip() or "powershell failed")
    answer = (cp.stdout or "").strip()
    if answer == "":
        return Result("cancelled", channel, "ask")
    return Result("answered", channel, "ask", response=answer)


def _win_confirm(req: Ask, channel: str) -> Result:
    wait = int(req.timeout) if req.has_timeout() else 0
    msg, title = req.message.replace('"', "'"), req.title.replace('"', "'")
    # Popup type 36 = Yes/No (4) + question icon (32). Returns 6=Yes, 7=No, -1=timeout.
    script = f'(New-Object -ComObject WScript.Shell).Popup("{msg}", {wait}, "{title}", 36)'
    cp = _powershell(script)
    code = (cp.stdout or "").strip()
    if code == "6":
        return Result("approved", channel, "confirm", response=req.yes)
    if code == "-1":
        return Result("timeout", channel, "confirm")
    return Result("denied", channel, "confirm", response=req.no)


# Platform -> verb dispatch tables for the system channel.
_MAC = {"notify": _mac_notify, "ask": _mac_ask, "confirm": _mac_confirm, "choose": _mac_choose}
_LINUX = {"notify": _linux_notify, "ask": _linux_ask, "confirm": _linux_confirm, "choose": _linux_choose}
_WIN = {"notify": _win_notify, "ask": _win_ask, "confirm": _win_confirm}


# --------------------------------------------------------------------------- #
# Shared reply parsing (used by every channel that reads a free-text reply back)
# --------------------------------------------------------------------------- #

# Words that count as "yes" for a confirm, in addition to the channel's own
# approve label. Anything not in this set is fail-closed to a denial.
_APPROVE_WORDS = {"y", "yes", "approve", "ok", "okay", "1", "true", "yep", "yeah", "sure"}


def _is_approval(reply: str, yes_label: str) -> bool:
    return reply.strip().lower() in (_APPROVE_WORDS | {yes_label.strip().lower()})


def _match_choice(reply: str, options: list) -> Optional[str]:
    """Map a human's reply to one option: a 1-based index or the option text."""
    reply = reply.strip()
    if reply.isdigit() and 1 <= int(reply) <= len(options):
        return options[int(reply) - 1]
    for opt in options:
        if reply.lower() == opt.lower():
            return opt
    return None


# --------------------------------------------------------------------------- #
# Channels
# --------------------------------------------------------------------------- #

class Channel:
    type = "base"

    def __init__(self, name: str, cfg: dict):
        self.name = name
        self.cfg = cfg

    def handle(self, req: Ask) -> Result:
        return getattr(self, req.verb)(req)

    def notify(self, req: Ask) -> Result:
        raise Unsupported(f"channel '{self.name}' ({self.type}) cannot notify")

    def ask(self, req: Ask) -> Result:
        raise Unsupported(f"channel '{self.name}' ({self.type}) cannot ask")

    def confirm(self, req: Ask) -> Result:
        raise Unsupported(f"channel '{self.name}' ({self.type}) cannot confirm")

    def choose(self, req: Ask) -> Result:
        raise Unsupported(f"channel '{self.name}' ({self.type}) cannot choose")


class SystemChannel(Channel):
    """Native desktop notification / dialog on the machine the agent runs on."""

    type = "system"

    def _table(self) -> dict:
        host = platform.system()
        table = {"Darwin": _MAC, "Linux": _LINUX, "Windows": _WIN}.get(host)
        if table is None:
            raise Unsupported(f"system channel does not support OS '{host}'")
        return table

    def _dispatch(self, verb: str, req: Ask) -> Result:
        fn = self._table().get(verb)
        if fn is None:
            raise Unsupported(f"system channel cannot '{verb}' on {platform.system()} "
                              "(no GUI helper available); configure a remote channel instead")
        return fn(req, self.name)

    def notify(self, req): return self._dispatch("notify", req)
    def ask(self, req): return self._dispatch("ask", req)
    def confirm(self, req): return self._dispatch("confirm", req)
    def choose(self, req): return self._dispatch("choose", req)


class NtfyChannel(Channel):
    """Push to an ntfy.sh topic; read the human's reply back off the same topic.

    Great for "the user is away from the keyboard but has their phone": they get
    a push notification and reply to the topic from the ntfy app.
    """

    type = "ntfy"

    def _server(self) -> str:
        return self.cfg.get("server", "https://ntfy.sh").rstrip("/")

    def _topic(self) -> str:
        topic = self.cfg.get("topic")
        if not topic:
            raise Unsupported(f"channel '{self.name}': ntfy requires a 'topic'")
        return topic

    def _auth(self) -> dict:
        token = self.cfg.get("token")
        return {"Authorization": f"Bearer {token}"} if token else {}

    def _publish(self, body: str, req: Ask) -> None:
        headers = dict(self._auth())
        headers["Title"] = NTFY_OUT_PREFIX + req.title
        headers["Priority"] = {"low": "low", "normal": "default", "high": "high"}.get(req.urgency, "default")
        request = urllib.request.Request(f"{self._server()}/{self._topic()}",
                                         data=body.encode("utf-8"), headers=headers, method="POST")
        urllib.request.urlopen(request, timeout=15).read()

    def _poll(self, since: float, deadline: float) -> Optional[str]:
        url = f"{self._server()}/{self._topic()}/json?since={int(since)}"
        while time.time() < deadline:
            try:
                request = urllib.request.Request(url, headers=self._auth())
                window = min(max(deadline - time.time(), 1), 30)
                with urllib.request.urlopen(request, timeout=window) as resp:
                    for raw in resp:
                        if time.time() >= deadline:
                            return None
                        reply = self._reply_from(raw)
                        if reply is not None:
                            return reply
            except (urllib.error.URLError, socket.timeout, TimeoutError, ConnectionError):
                time.sleep(1)
        return None

    @staticmethod
    def _reply_from(raw: bytes) -> Optional[str]:
        line = raw.decode("utf-8", "replace").strip()
        if not line:
            return None
        try:
            msg = json.loads(line)
        except json.JSONDecodeError:
            return None
        if msg.get("event") != "message":
            return None
        if str(msg.get("title", "")).startswith(NTFY_OUT_PREFIX):  # ignore our own publish
            return None
        return msg.get("message") or None

    def notify(self, req: Ask) -> Result:
        try:
            self._publish(req.message, req)
            return Result("delivered", self.name, "notify")
        except Exception as exc:                                   # noqa: BLE001
            return Result("error", self.name, "notify", error=f"ntfy publish failed: {exc}")

    def _round_trip(self, body: str, req: Ask) -> Optional[str]:
        start = time.time()
        self._publish(body, req)
        deadline = start + (req.timeout if req.has_timeout() else 86400)
        return self._poll(start, deadline)

    def ask(self, req: Ask) -> Result:
        body = f"{req.message}\n\nReply to this topic to answer."
        try:
            reply = self._round_trip(body, req)
        except Exception as exc:                                   # noqa: BLE001
            return Result("error", self.name, "ask", error=f"ntfy ask failed: {exc}")
        if reply is None:
            return Result("timeout", self.name, "ask")
        return Result("answered", self.name, "ask", response=reply)

    def confirm(self, req: Ask) -> Result:
        body = f"{req.message}\n\nReply '{req.yes}'/yes to approve or '{req.no}'/no to deny."
        try:
            reply = self._round_trip(body, req)
        except Exception as exc:                                   # noqa: BLE001
            return Result("error", self.name, "confirm", error=f"ntfy confirm failed: {exc}")
        if reply is None:
            return Result("timeout", self.name, "confirm")
        if _is_approval(reply, req.yes):
            return Result("approved", self.name, "confirm", response=reply)
        return Result("denied", self.name, "confirm", response=reply)   # fail-closed on anything else

    def choose(self, req: Ask) -> Result:
        listing = "\n".join(f"{i + 1}. {opt}" for i, opt in enumerate(req.options))
        body = f"{req.message}\n\n{listing}\n\nReply with the number or the text."
        try:
            reply = self._round_trip(body, req)
        except Exception as exc:                                   # noqa: BLE001
            return Result("error", self.name, "choose", error=f"ntfy choose failed: {exc}")
        if reply is None:
            return Result("timeout", self.name, "choose")
        picked = _match_choice(reply, req.options)
        if picked is None:
            return Result("cancelled", self.name, "choose", response=reply)
        return Result("chosen", self.name, "choose", response=picked)


class WebhookChannel(Channel):
    """One-way HTTP POST. Defaults to a Slack-style {"text": ...} body."""

    type = "webhook"

    def notify(self, req: Ask) -> Result:
        url = self.cfg.get("url")
        if not url:
            raise Unsupported(f"channel '{self.name}': webhook requires a 'url'")
        template = self.cfg.get("body")
        if template:
            data = template.format(message=req.message, title=req.title).encode("utf-8")
            content_type = self.cfg.get("content_type", "application/json")
        else:
            data = json.dumps({"text": f"{req.title}: {req.message}"}).encode("utf-8")
            content_type = "application/json"
        try:
            request = urllib.request.Request(url, data=data, method="POST",
                                             headers={"Content-Type": content_type})
            for key, value in (self.cfg.get("headers") or {}).items():
                request.add_header(key, value)
            urllib.request.urlopen(request, timeout=15).read()
            return Result("delivered", self.name, "notify")
        except Exception as exc:                                   # noqa: BLE001
            return Result("error", self.name, "notify", error=f"webhook failed: {exc}")


class CommandChannel(Channel):
    """Run a user-defined program per verb. The escape hatch for anything the
    other channels do not cover (say, terminal-notifier, a Telegram CLI, a
    text-to-speech command). Placeholders {message} {title} {default} {options}
    are substituted into argv and optional stdin."""

    type = "command"

    def _argv(self, verb: str, req: Ask) -> list:
        spec = self.cfg.get(verb)
        if not spec:
            raise Unsupported(f"channel '{self.name}': command channel has no '{verb}' configured")
        return [self._fmt(arg, req) for arg in spec]

    @staticmethod
    def _fmt(text: str, req: Ask) -> str:
        return text.format(message=req.message, title=req.title,
                           default=req.default, options=", ".join(req.options))

    def _run(self, verb: str, req: Ask) -> subprocess.CompletedProcess:
        stdin = self.cfg.get("stdin")
        return subprocess.run(self._argv(verb, req), capture_output=True, text=True,
                              input=(self._fmt(stdin, req) if stdin else None),
                              timeout=(req.timeout if req.has_timeout() else None))

    def notify(self, req: Ask) -> Result:
        cp = self._run("notify", req)
        if cp.returncode != 0:
            return Result("error", self.name, "notify", error=(cp.stderr or "").strip() or "command failed")
        return Result("delivered", self.name, "notify")

    def ask(self, req: Ask) -> Result:
        try:
            cp = self._run("ask", req)
        except subprocess.TimeoutExpired:
            return Result("timeout", self.name, "ask")
        if cp.returncode != 0:
            return Result("cancelled", self.name, "ask")
        return Result("answered", self.name, "ask", response=(cp.stdout or "").strip())

    def confirm(self, req: Ask) -> Result:
        try:
            cp = self._run("confirm", req)
        except subprocess.TimeoutExpired:
            return Result("timeout", self.name, "confirm")
        if cp.returncode == 0:
            return Result("approved", self.name, "confirm", response=req.yes)
        return Result("denied", self.name, "confirm", response=req.no)

    def choose(self, req: Ask) -> Result:
        try:
            cp = self._run("choose", req)
        except subprocess.TimeoutExpired:
            return Result("timeout", self.name, "choose")
        if cp.returncode != 0:
            return Result("cancelled", self.name, "choose")
        return Result("chosen", self.name, "choose", response=(cp.stdout or "").strip())


class BannerChannel(Channel):
    """macOS notify banners with a logo image (terminal-notifier). Opt in via setup-logo."""

    type = "banner"

    def _logo(self) -> Path:
        raw = self.cfg.get("logo")
        if raw:
            path = Path(raw).expanduser()
            if path.is_file():
                return path
            raise Unsupported(f"channel '{self.name}': logo not found at {path}")
        found = default_logo_path()
        if found is None:
            raise Unsupported(f"channel '{self.name}': no logo.png; run agentping setup-logo")
        return found

    def _terminal_notifier(self) -> str:
        raw = self.cfg.get("terminal_notifier")
        if raw:
            path = Path(raw).expanduser()
            if path.is_file() and os.access(path, os.X_OK):
                return str(path)
            raise Unsupported(f"channel '{self.name}': terminal-notifier not found at {path}")
        found = shutil.which("terminal-notifier")
        if found is None:
            raise Unsupported(
                f"channel '{self.name}': terminal-notifier not installed; run agentping setup-logo")
        return found

    def notify(self, req: Ask) -> Result:
        if platform.system() != "Darwin":
            raise Unsupported(f"channel '{self.name}': banner channel is macOS only")
        logo = str(self._logo())
        tn = self._terminal_notifier()
        argv = [tn, "-title", req.title, "-message", req.message, "-contentImage", logo]
        if req.sound:
            argv.extend(["-sound", req.sound])
        sender = self.cfg.get("sender")
        if sender:
            argv.extend(["-sender", sender])
        cp = subprocess.run(argv, capture_output=True, text=True)
        if cp.returncode != 0:
            err = (cp.stderr or cp.stdout or "").strip() or "terminal-notifier failed"
            return Result("error", self.name, "notify", error=err)
        return Result("delivered", self.name, "notify")


def _same_handle(want: str, got: str) -> bool:
    """True if two Messages handles are the same person. Emails compare exactly;
    phone numbers compare by their last 10 digits so +1 / spacing don't matter."""
    want, got = want.strip(), got.strip()
    if "@" in want or "@" in got:
        return want.lower() == got.lower()
    digits_want = re.sub(r"\D", "", want)[-10:]
    digits_got = re.sub(r"\D", "", got)[-10:]
    return bool(digits_want) and digits_want == digits_got


def _attributed_text(blob) -> str:
    """Best-effort plain text from a Messages `attributedBody` blob. Newer macOS
    leaves the `text` column NULL and stores the body as an NSAttributedString
    typedstream; the readable string sits right after the 'NSString'/'+' marker,
    length-prefixed. Returns '' if it cannot be decoded (the text column covers
    the common case), so this never raises into the poll loop."""
    if not blob:
        return ""
    try:
        data = bytes(blob)
        marker = data.find(b"NSString")
        if marker == -1:
            return ""
        plus = data.find(b"+", marker)
        if plus == -1 or plus + 1 >= len(data):
            return ""
        i = plus + 1
        length = data[i]
        i += 1
        if length == 0x81:                       # 2-byte little-endian length follows
            if i + 2 > len(data):
                return ""
            length = int.from_bytes(data[i:i + 2], "little")
            i += 2
        return data[i:i + length].decode("utf-8", "replace").strip()
    except Exception:                            # noqa: BLE001 -- backstop, never fatal
        return ""


def _imessage_error(stderr: str) -> Unsupported:
    """Turn an osascript failure into a typed error that names the fix."""
    s = (stderr or "").strip()
    low = s.lower()
    if "-1743" in s or "not authorized" in low:
        return Unsupported(
            "Messages automation is not authorized. Grant your terminal/agent permission "
            "in System Settings > Privacy & Security > Automation (allow controlling "
            "Messages). Note: messages cannot be sent from an SSH session.")
    if "-10000" in s or "handler failed" in low:
        return Unsupported(
            "Messages refused the send (-10000). Open Messages.app, sign in to iMessage, "
            "and text this recipient once by hand; then approve the Automation prompt.")
    return Unsupported(s or "osascript failed to send via Messages")


class IMessageChannel(Channel):
    """Send through the macOS Messages app under your own iMessage/SMS account, to
    any phone number or Apple ID. Outbound uses AppleScript (a direct buddy send,
    which sidesteps the macOS 26 group "ghost row" bug). The blocking verbs read
    your reply back from ~/Library/Messages/chat.db, so it is fully two-way like
    ntfy -- you answer from your phone and the agent unblocks.

    Requires (one time): Messages signed in to iMessage; Automation permission for
    your terminal/agent to control Messages (to send); Full Disk Access for your
    terminal/agent (to read replies). macOS only.
    """

    type = "imessage"

    def _to(self) -> str:
        to = self.cfg.get("to")
        if not to:
            raise Unsupported(f"channel '{self.name}': imessage requires a 'to' (phone or Apple ID)")
        return str(to)

    def _service(self) -> str:
        svc = self.cfg.get("service", "iMessage")
        if svc not in ("iMessage", "SMS"):
            raise Unsupported(f"channel '{self.name}': service must be 'iMessage' or 'SMS', got {svc!r}")
        return svc

    def _send(self, body: str) -> None:
        if platform.system() != "Darwin":
            raise Unsupported(f"channel '{self.name}': imessage is macOS only")
        script = (
            "on run argv\n"
            "  set toHandle to item 1 of argv\n"
            "  set msg to item 2 of argv\n"
            "  tell application \"Messages\"\n"
            f"    set targetService to id of 1st account whose service type = {self._service()}\n"
            "    set theBuddy to participant toHandle of account id targetService\n"
            "    send msg to theBuddy\n"
            "  end tell\n"
            "end run\n"
        )
        start = time.time()
        cp = subprocess.run(["osascript", "-e", script, self._to(), body],
                            capture_output=True, text=True)
        if cp.returncode != 0:
            raise _imessage_error(cp.stderr)
        self._verify_delivery(start)

    def _verify_delivery(self, start_unix: float) -> None:
        """AppleScript's `send` returns success once Messages *accepts* the send,
        not once Apple *delivers* it -- a wrong number or a recipient who isn't on
        iMessage still shows "Not Delivered" in the app. When chat.db is readable
        (Full Disk Access), watch the outgoing row and raise if Messages flags a
        send error, so we never report a false 'delivered'. Without Full Disk
        Access we cannot check, so we stay quiet rather than lie either way.
        Disable with "verify": false; bound the wait with "verify_timeout"."""
        if self.cfg.get("verify") is False:
            return
        db = Path.home() / "Library" / "Messages" / "chat.db"
        if not db.is_file():
            return
        cutoff_ns = int((start_unix - APPLE_EPOCH) * 1_000_000_000)
        target = self._to()
        deadline = time.time() + float(self.cfg.get("verify_timeout", 6))
        while time.time() < deadline:
            try:
                state = self._outgoing_state(db, cutoff_ns, target)
            except sqlite3.OperationalError:
                return                               # no Full Disk Access: cannot verify
            if state is not None:
                error_code, delivered = state
                if error_code:
                    raise RuntimeError(
                        f"Messages could not deliver to {target} (error {error_code}). Check the "
                        "number/Apple ID is correct and reachable on iMessage.")
                if delivered:
                    return
            time.sleep(0.4)

    @staticmethod
    def _outgoing_state(db: Path, cutoff_ns: int, target: str) -> Optional[tuple]:
        con = sqlite3.connect(f"file:{db}?mode=ro", uri=True)
        try:
            rows = con.execute(
                "SELECT m.error, m.is_delivered, h.id FROM message m "
                "JOIN handle h ON m.handle_id = h.ROWID "
                "WHERE m.is_from_me = 1 AND m.date > ? ORDER BY m.date DESC LIMIT 10",
                (cutoff_ns,)).fetchall()
        finally:
            con.close()
        for error_code, delivered, handle in rows:
            if _same_handle(target, handle or ""):
                return (error_code or 0, bool(delivered))
        return None

    def _reply_after(self, start_unix: float, deadline: float) -> Optional[str]:
        db = Path.home() / "Library" / "Messages" / "chat.db"
        if not db.is_file():
            raise Unsupported(f"channel '{self.name}': Messages database not found at {db}")
        cutoff_ns = int((start_unix - APPLE_EPOCH) * 1_000_000_000)
        interval = float(self.cfg.get("poll_interval", 3))
        while time.time() < deadline:
            reply = self._latest_reply(db, cutoff_ns)
            if reply:
                return reply
            time.sleep(max(min(interval, deadline - time.time()), 0))
        return None

    def _latest_reply(self, db: Path, cutoff_ns: int) -> Optional[str]:
        try:
            con = sqlite3.connect(f"file:{db}?mode=ro", uri=True)
            try:
                rows = con.execute(
                    "SELECT m.text, m.attributedBody, h.id FROM message m "
                    "JOIN handle h ON m.handle_id = h.ROWID "
                    "WHERE m.is_from_me = 0 AND m.date > ? ORDER BY m.date ASC",
                    (cutoff_ns,)).fetchall()
            finally:
                con.close()
        except sqlite3.OperationalError as exc:
            raise Unsupported(
                f"channel '{self.name}': cannot read the Messages database ({exc}). Grant Full "
                "Disk Access to your terminal/agent in System Settings > Privacy & Security.")
        target = self._to()
        for text, attr, handle in rows:
            if not _same_handle(target, handle or ""):
                continue
            body = (text or "").strip() or _attributed_text(attr)
            if body:
                return body.strip()
        return None

    def _round_trip(self, body: str, req: Ask) -> Optional[str]:
        start = time.time()
        self._send(body)
        deadline = start + (req.timeout if req.has_timeout() else 86400)
        return self._reply_after(start, deadline)

    def notify(self, req: Ask) -> Result:
        try:
            self._send(req.message)
        except Unsupported:
            raise
        except Exception as exc:                                   # noqa: BLE001
            return Result("error", self.name, "notify", error=f"imessage send failed: {exc}")
        return Result("delivered", self.name, "notify")

    def ask(self, req: Ask) -> Result:
        try:
            reply = self._round_trip(f"{req.message}\n\nReply to this message to answer.", req)
        except Unsupported:
            raise
        except Exception as exc:                                   # noqa: BLE001
            return Result("error", self.name, "ask", error=f"imessage ask failed: {exc}")
        if reply is None:
            return Result("timeout", self.name, "ask")
        return Result("answered", self.name, "ask", response=reply)

    def confirm(self, req: Ask) -> Result:
        body = f"{req.message}\n\nReply '{req.yes}'/yes to approve or '{req.no}'/no to deny."
        try:
            reply = self._round_trip(body, req)
        except Unsupported:
            raise
        except Exception as exc:                                   # noqa: BLE001
            return Result("error", self.name, "confirm", error=f"imessage confirm failed: {exc}")
        if reply is None:
            return Result("timeout", self.name, "confirm")
        if _is_approval(reply, req.yes):
            return Result("approved", self.name, "confirm", response=reply)
        return Result("denied", self.name, "confirm", response=reply)

    def choose(self, req: Ask) -> Result:
        listing = "\n".join(f"{i + 1}. {opt}" for i, opt in enumerate(req.options))
        body = f"{req.message}\n\n{listing}\n\nReply with the number or the text."
        try:
            reply = self._round_trip(body, req)
        except Unsupported:
            raise
        except Exception as exc:                                   # noqa: BLE001
            return Result("error", self.name, "choose", error=f"imessage choose failed: {exc}")
        if reply is None:
            return Result("timeout", self.name, "choose")
        picked = _match_choice(reply, req.options)
        if picked is None:
            return Result("cancelled", self.name, "choose", response=reply)
        return Result("chosen", self.name, "choose", response=picked)


def _twilio_error(exc: urllib.error.HTTPError) -> str:
    try:
        body = json.loads(exc.read() or b"{}")
        return body.get("message") or f"HTTP {exc.code}"
    except Exception:                                              # noqa: BLE001
        return f"HTTP {getattr(exc, 'code', '?')}"


class SMSChannel(Channel):
    """Outbound SMS through Twilio's REST API: the external-provider path for
    reaching a phone that is not on iMessage, or for sending from a non-Mac /
    headless host. Notify only -- inbound SMS needs a public webhook, which is out
    of scope; use `imessage` (macOS) or `ntfy` (any OS) when you need the reply.

    Config keys (or the matching env vars, so secrets can stay out of the file):
    account_sid/$TWILIO_ACCOUNT_SID, auth_token/$TWILIO_AUTH_TOKEN,
    from/$TWILIO_FROM (your Twilio number), to/$TWILIO_TO (the recipient).
    """

    type = "sms"
    API = "https://api.twilio.com/2010-04-01"

    def _need(self, key: str, env: str) -> str:
        val = self.cfg.get(key) or os.environ.get(env)
        if not val:
            raise Unsupported(f"channel '{self.name}': sms requires '{key}' in config or ${env}")
        return str(val)

    def notify(self, req: Ask) -> Result:
        sid = self._need("account_sid", "TWILIO_ACCOUNT_SID")
        token = self._need("auth_token", "TWILIO_AUTH_TOKEN")
        frm = self._need("from", "TWILIO_FROM")
        to = self._need("to", "TWILIO_TO")
        text = req.message if req.title in ("", "Agent") else f"{req.title}: {req.message}"
        data = urllib.parse.urlencode({"From": frm, "To": to, "Body": text}).encode("utf-8")
        url = f"{self.API}/Accounts/{urllib.parse.quote(sid)}/Messages.json"
        auth = base64.b64encode(f"{sid}:{token}".encode("utf-8")).decode("ascii")
        request = urllib.request.Request(url, data=data, method="POST",
                                         headers={"Authorization": f"Basic {auth}"})
        try:
            with urllib.request.urlopen(request, timeout=20) as resp:
                payload = json.loads(resp.read() or b"{}")
        except urllib.error.HTTPError as exc:
            return Result("error", self.name, "notify", error=f"twilio: {_twilio_error(exc)}")
        except Exception as exc:                                   # noqa: BLE001
            return Result("error", self.name, "notify", error=f"twilio request failed: {exc}")
        if payload.get("status") in ("failed", "undelivered"):
            return Result("error", self.name, "notify",
                          error=f"twilio status {payload.get('status')}: {payload.get('error_message')}")
        return Result("delivered", self.name, "notify")


_CHANNEL_TYPES = {
    "system": SystemChannel,
    "ntfy": NtfyChannel,
    "webhook": WebhookChannel,
    "command": CommandChannel,
    "banner": BannerChannel,
    "imessage": IMessageChannel,
    "sms": SMSChannel,
}


